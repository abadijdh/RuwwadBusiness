# انسخ هذا الملف إلى `.env` وعدّل القيم. لا ترفع `.env` إلى Git (موجود في .gitignore).

PORT=5000

# Atlas أو أي MongoDB — سلسلة كاملة مع ssl إن لزم
MONGO_URI=

# عند الرفع على دومين حقيقي ضع الرابط العام (بدون شرطة مائلة أخيرة)
# مهم لقوالب التبليغ وتصدير CSV بحيث تكون الروابط https صحيحة وليست localhost
# PUBLIC_URL=https://beta.example.com

# للتطوير فقط — يعيد كود OTP في JSON عند التحقق من جوال
# DEV_OTP_HINT=1

# لوحة الطاقم — ضع كلمة مرور قوية على الإنتاج (Render). إذا تركتها فارغة تُعرَض اللوحة بدون حماية.
TEAM_PANEL_PASSWORD=

# اختياري: لوحة الطاقم على مسار غير معروف بدل /team.html (مثال: internal-roaad-2026)
# TEAM_PANEL_SECRET_PATH=
